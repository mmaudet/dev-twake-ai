# Copy to .env (gitignored) and fill in the values, or place a copy at
# ~/.kanbn/kanbn.env. run.sh reads from ~/.kanbn/kanbn.env if it exists,
# otherwise from .env next to docker-compose.yml.

NEXT_PUBLIC_BASE_URL=https://kanbn.dev-twake.maudet.cloud

# 32+ char base64-safe secret. Generate with:
#   openssl rand -base64 26 | tr -dc 'a-zA-Z0-9' | head -c 32
BETTER_AUTH_SECRET=

# All Cozy app subdomains that may host the iframe pointing at kan,
# comma-separated.
BETTER_AUTH_TRUSTED_ORIGINS=https://kanbn.dev-twake.maudet.cloud,https://mmaudet-kanbn.dev-twake.maudet.cloud,https://bandre-kanbn.dev-twake.maudet.cloud,https://qvalmori-kanbn.dev-twake.maudet.cloud,https://zbellot-kanbn.dev-twake.maudet.cloud,https://dpotokina-kanbn.dev-twake.maudet.cloud

POSTGRES_PASSWORD=
POSTGRES_URL=postgresql://kan:<POSTGRES_PASSWORD>@postgres:5432/kan_db

# Authelia OIDC client (declared in /opt/authelia/config/configuration.yml on hermes)
OIDC_CLIENT_ID=kanbn
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=https://auth.maudet.cloud/.well-known/openid-configuration

# SMTP (Linagora)
SMTP_HOST=smtp.linagora.com
SMTP_PORT=587
SMTP_USER=mmaudet@linagora.com
SMTP_PASSWORD=
EMAIL_FROM=Kan <mmaudet@linagora.com>

LOG_LEVEL=info
