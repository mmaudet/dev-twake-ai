# Copy to ~/.grist/grist.env (gitignored) and fill in the secrets.

# Random 32+ char base64 secret for the OIDC client. Must match the
# pbkdf2 hash declared under identity_providers.oidc.clients[].client_secret
# for client_id 'grist' in /opt/authelia/config/configuration.yml on hermes.
GRIST_OIDC_CLIENT_SECRET=

# Random base64 secret used by Grist to sign its session cookies.
# openssl rand -base64 32
GRIST_SESSION_SECRET=

# Optional overrides:
# GRIST_SINGLE_ORG=twake-dev
# GRIST_DEFAULT_EMAIL=michel.maudet@gmail.com
